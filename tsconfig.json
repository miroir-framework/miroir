{
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/__tests__/*"
  ],
  "compilerOptions": {
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strictNullChecks": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports":true,
		"forceConsistentCasingInFileNames": true,
    "types": ["node", "jest"],
    "lib": ["es2022", "dom"],
    "removeComments": true,
    "jsx": "react-jsx",
    "allowJs": true
  }
}