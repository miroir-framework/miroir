{
  "name": "miroir-store-postgres",
  "private": true,
  "version": "0.0.0",
  "author": "Miroir Framework <miroir-framework@protonmail.com>",
  "license": "MIT",
  "description": "The Miroir implementation for accessing Postgres databases.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "type": "module",
  "scripts": {
    "watch": "lerna watch --scope='miroir-store-postgres' --include-dependencies -- lerna run build --scope='miroir-store-postgres'",
    "build-tsup": "tsup",
    "build": "npm run build-tsup",
    "devBuild": "npm run build",
    "copy-files": "copyfiles -u 1 src/**/*.json src/**/*.css dist/src",
    "test": "jest --verbose --silent=false -t",
    "vitest": "cross-env VITE_TEST_MODE='true' vitest run --reporter=verbose --poolOptions.forks.singleFork --bail=1",
    "generate-ts-types": "tsx ./scripts/postgres-generate-ts-types.ts"
  },
  "dependencies": {
    "miroir-core": "*",
    "pg": "^8.9.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.25.7",
    "@jest/globals": "^29.3.1",
    "@miroir-framework/jzod-ts": "0.8.2",
    "@types/jest": "^29.2.4",
    "copyfiles": "^2.4.1",
    "loglevelnext": "^6.0.0",
    "rimraf": "^4.1.1",
    "ts-jest": "^29.1.1",
    "tsconfig-paths": "^4.1.2",
    "tsup": "^8.0.1",
    "typescript": "^6.0.0"
  }
}
