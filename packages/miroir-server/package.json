{
  "name": "miroir-server",
  "version": "1.0.0",
  "description": "server for mirroir-based front-end",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "build:client": "npm run build -w miroir-standalone-app",
    "copy:client": "node scripts/copy-client.mjs",
    "copy:release-config": "copyfiles -u 1 config/**/*.json release/config",
    "build:server": "tsup --target=node20 --format esm src/server.ts --outDir release",
    "build:release": "npm run build:client && npm run copy:client && npm run copy:release-config && npm run build:server",
    "run:prod": "cross-env NODE_ENV=production node release/server.js",
    "help": "vite-node -h",
    "copy-files": "copyfiles -u 1 src/**/*.json src/**/*.css dist/src",
    "copy-config": "copyfiles -u 1 config/**/*.json dist/config",
    "copy-all": "npm run copy-files && npm run copy-config",
    "build-tsup": "npm run copy-all && tsup --target=node20 --format esm src/server.ts",
    "build:dev": "npm run build-tsup",
    "build": "npm run build:dev",
    "devBuild": "npm run build",
    "run:dev": "cross-env NODE_ENV=development nodemon ./dist/server.js localhost 3080",
    "test": "cross-env NODE_ENV=test vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XXXXXXXXXXXXXXXXXXXXXXXX.git"
  },
  "author": "Miroir Framework <miroir-framework@protonmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/XXXXXXXXXXXXXXXXXXXXXXXXX/issues"
  },
  "homepage": "https://github.com/XXXXXXXXXXXXXXXXXXXXXXXXXXX#readme",
  "nodemonConfig": {
    "ignore": [
      "**/test/**",
      "**/tests/**",
      "**/docs/**"
    ]
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "cross-fetch": "^4.0.0",
    "diff": "8.0.3",
    "electron": "^40.6.1",
    "electron-builder": "26.8.1",
    "express": "^4.21.2",
    "happy-dom": "20.7.0",
    "http-proxy-middleware": "^3.0.5",
    "isomorphic-git": "^1.23.0",
    "loglevelnext": "^6.0.0",
    "miroir-core": "*",
    "miroir-localcache-redux": "*",
    "miroir-mcp": "*",
    "miroir-store-filesystem": "*",
    "miroir-store-indexedDb": "*",
    "miroir-store-mongodb": "*",
    "miroir-store-postgres": "*",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "@babel/register": "^7.22.15",
    "@types/body-parser": "^1.19.6",
    "@types/express": "^5.0.0",
    "@types/node": "^18.14.4",
    "babel-loader": "^10.0.0",
    "concurrently": "^7.6.0",
    "nodemon": "^3.1.14",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.1.2",
    "tsup": "^8.0.1",
    "typescript": "^6.0.0",
    "vite-plugin-node": "^7.0.0",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.0",
    "webpack-node-externals": "^3.0.0"
  }
}
