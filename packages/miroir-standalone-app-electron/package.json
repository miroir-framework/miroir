{
  "name": "miroir-standalone-app-electron",
  "version": "0.5.0-rc.1",
  "description": "Electron desktop application wrapper for miroir-standalone-app",
  "author": "Miroir Framework <miroir-framework@protonmail.com>",
  "homepage": "https://github.com/miroir-framework/miroir/packages/miroir-standalone-app-electron/#readme",
  "bugs": "https://github.com/miroir-framework/miroir/issues",
  "license": "MIT",
  "main": "dist/src/main.js",
  "type": "module",
  "private": true,
  "scripts": {
    "build-main": "npx tsc src/main.ts --ignoreConfig --outDir dist --target es2020 --module esnext --moduleResolution bundler --allowSyntheticDefaultImports --strict --skipLibCheck",
    "build-preload": "npx tsc src/preload.ts --ignoreConfig --ignoreDeprecations 6.0 --outDir dist/src --target es2020 --module commonjs --moduleResolution node --allowSyntheticDefaultImports --strict --skipLibCheck",
    "build-electron": "npm run build-main && npm run build-preload",
    "build": "npm run build-electron",
    "electron": "npm run build-electron && electron .",
    "electron-dev": "npm run build-electron && electron . --dev",
    "pack": "npm run build-electron && electron-builder --dir",
    "dist": "npm run build-electron && electron-builder",
    "dist-win": "npm run build-electron && electron-builder --win",
    "dist-mac": "npm run build-electron && electron-builder --mac",
    "dist-linux": "npm run build-electron && electron-builder --linux"
  },
  "dependencies": {
    "diff": "8.0.3",
    "electron-squirrel-startup": "^1.0.1",
    "happy-dom": "20.7.0",
    "http-proxy-middleware": "3.0.5",
    "miroir-core": "*",
    "miroir-localcache-redux": "*",
    "miroir-standalone-app": "*",
    "miroir-store-filesystem": "*",
    "miroir-store-indexedDb": "*",
    "miroir-store-mongodb": "*",
    "miroir-store-postgres": "*",
    "miroir-test-app_deployment-admin": "*",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.8.9",
    "electron": "40.6.1",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.0"
  },
  "build": {
    "appId": "com.miroir-framework.miroir-standalone-app-electron",
    "productName": "Miroir Standalone App",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../miroir-standalone-app/dist",
        "to": "app",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../miroir-test-app_deployment-admin/assets/admin_data",
        "to": "miroir-assets/miroir-test-app_deployment-admin/assets/admin_data",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../miroir-test-app_deployment-admin/assets/admin_model",
        "to": "miroir-assets/miroir-test-app_deployment-admin/assets/admin_model",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../miroir-test-app_deployment-miroir/assets",
        "to": "miroir-assets/miroir-test-app_deployment-miroir/assets",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../miroir-test-app_deployment-library/dist",
        "to": "miroir-assets/bundles",
        "filter": [
          "library-model*.json",
          "library-data*.json"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/miroir-logo.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/miroir-logo.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/miroir-logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
