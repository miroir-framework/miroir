  "name": "EntityPrimaryKey",
  "description": "Phase 5c — EntityPrimaryKey helpers",
  "definition": {
    "unitTestType": "unitTestSuite",
    "unitTestLabel": "EntityPrimaryKey",
    "unitTests": [
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "returns instance.parentUuid when present",
        "functionRef": {
          "module": "miroir-core/1_core/EntityPrimaryKey",
          "export": "resolveInstanceParentUuid"
        },
        "arguments": [
          {
            "uuid": "00000000-0000-0000-0000-000000000001",
            "parentUuid": "aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee",
            "parentName": "SomeEntity"
          },
          "11111111-2222-3333-4444-555555555555"
        ],
        "expectedValue": "aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee"
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "falls back to payloadParentUuid when instance.parentUuid is absent",
        "functionRef": {
          "module": "miroir-core/1_core/EntityPrimaryKey",
          "export": "resolveInstanceParentUuid"
        },
        "arguments": [
          {
            "uuid": "00000000-0000-0000-0000-000000000002"
          },
          "11111111-2222-3333-4444-555555555555"
        ],
        "expectedValue": "11111111-2222-3333-4444-555555555555"
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "falls back to payloadParentUuid when instance.parentUuid is undefined",
        "functionRef": {
          "module": "miroir-core/1_core/EntityPrimaryKey",
          "export": "resolveInstanceParentUuid"
        },
        "arguments": [
          {
            "uuid": "00000000-0000-0000-0000-000000000003",
            "parentUuid": {
              "__miroirJsonUndefined": true
            }
          },
          "11111111-2222-3333-4444-555555555555"
        ],
        "expectedValue": "11111111-2222-3333-4444-555555555555"
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "returns Action2Error when both parentUuid sources are absent",
        "functionRef": {
          "module": "miroir-core/1_core/EntityPrimaryKey",
          "export": "resolveInstanceParentUuid"
        },
        "arguments": [
          {
            "uuid": "00000000-0000-0000-0000-000000000004"
          },
          {
            "__miroirJsonUndefined": true
          }
        ],
        "expectedAction2ErrorType": "FailedToResolveParentUuid"
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "returns Action2Error when both sources are empty string",
        "functionRef": {
          "module": "miroir-core/1_core/EntityPrimaryKey",
          "export": "resolveInstanceParentUuid"
        },
        "arguments": [
          {
            "uuid": "00000000-0000-0000-0000-000000000005",
            "parentUuid": ""
          },
          ""
        ],
        "expectedAction2ErrorType": "FailedToResolveParentUuid"
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "prefers instance.parentUuid over payloadParentUuid",
        "functionRef": {
          "module": "miroir-core/1_core/EntityPrimaryKey",
          "export": "resolveInstanceParentUuid"
        },
        "arguments": [
          {
            "uuid": "00000000-0000-0000-0000-000000000006",
            "parentUuid": "aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee"
          },
          "11111111-2222-3333-4444-555555555555"
        ],
        "expectedValue": "aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee"
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "works with instance cast from a plain object without parentUuid",
        "functionRef": {
          "module": "miroir-core/1_core/EntityPrimaryKey",
          "export": "resolveInstanceParentUuid"
        },
        "arguments": [
          {
            "uuid": "00000000-0000-0000-0000-000000000007",
            "name": "plain"
          },
          "11111111-2222-3333-4444-555555555555"
        ],
        "expectedValue": "11111111-2222-3333-4444-555555555555"
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "returns single string for single-attribute PK",
        "functionRef": {
          "module": "miroir-core/1_core/EntityPrimaryKey",
          "export": "getEntityPrimaryKeyAttribute"
        },
        "arguments": [
          {
            "idAttribute": "code"
