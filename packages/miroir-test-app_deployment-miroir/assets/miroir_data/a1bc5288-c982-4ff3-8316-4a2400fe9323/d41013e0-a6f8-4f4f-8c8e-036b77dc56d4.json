        "expectedValue": [
          "code"
        ]
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "returns array as-is for composite PK",
        "functionRef": {
          "module": "miroir-core/1_core/EntityPrimaryKey",
