      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "single-attribute: returns plain string value",
        "functionRef": {
          "module": "miroir-core/1_core/EntityPrimaryKey",
          "export": "serializeCompositeKeyValue"
        },
        "arguments": [
          [
            "code"
          ],
          {
            "code": 42
          }
        ],
        "expectedValue": "42"
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "single-attribute round-trip",
        "functionRef": {
          "module": "miroir-core/1_core/EntityPrimaryKey",
          "export": "parseCompositeKeyValue"
        },
        "arguments": [
          [
            "code"
          ],
          "42"
        ],
        "expectedValue": {
          "code": "42"
        }
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "composite: joins with | separator",
        "functionRef": {
          "module": "miroir-core/1_core/EntityPrimaryKey",
          "export": "serializeCompositeKeyValue"
        },
        "arguments": [
          [
            "table_schema",
            "table_name",
            "column_name"
          ],
          {
            "table_schema": "public",
            "table_name": "users",
            "column_name": "id"
          }
        ],
        "expectedValue": "public|users|id"
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "composite round-trip",
        "functionRef": {
          "module": "miroir-core/1_core/EntityPrimaryKey",
          "export": "parseCompositeKeyValue"
        },
        "arguments": [
          [
            "table_schema",
            "table_name",
            "column_name"
          ],
          "public|users|id"
        ],
        "expectedValue": {
          "table_schema": "public",
          "table_name": "users",
          "column_name": "id"
        }
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "escapes | in values",
        "functionRef": {
          "module": "miroir-core/1_core/EntityPrimaryKey",
          "export": "serializeCompositeKeyValue"
        },
        "arguments": [
          [
            "a",
            "b"
          ],
          {
            "a": "val|ue",
            "b": "normal"
          }
        ],
        "expectedValue": "val\\|ue|normal"
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "unescapes | in values",
        "functionRef": {
          "module": "miroir-core/1_core/EntityPrimaryKey",
          "export": "parseCompositeKeyValue"
        },
        "arguments": [
          [
            "a",
            "b"
          ],
          "val\\|ue|normal"
        ],
        "expectedValue": {
          "a": "val|ue",
          "b": "normal"
        }
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "escapes backslash in values",
        "functionRef": {
          "module": "miroir-core/1_core/EntityPrimaryKey",
          "export": "serializeCompositeKeyValue"
        },
        "arguments": [
          [
            "a",
            "b"
          ],
          {
            "a": "val\\ue",
            "b": "ok"
          }
        ],
        "expectedValue": "val\\\\ue|ok"
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "unescapes backslash in values",
        "functionRef": {
          "module": "miroir-core/1_core/EntityPrimaryKey",
          "export": "parseCompositeKeyValue"
        },
        "arguments": [
          [
            "a",
            "b"
          ],
          "val\\\\ue|ok"
        ],
        "expectedValue": {
          "a": "val\\ue",
          "b": "ok"
        }
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "handles empty string values",
        "functionRef": {
          "module": "miroir-core/1_core/EntityPrimaryKey",
          "export": "serializeCompositeKeyValue"
        },
        "arguments": [
          [
            "a",
            "b"
          ],
          {
            "a": "",
            "b": "x"
          }
        ],
        "expectedValue": "|x"
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "handles empty string values round-trip",
        "functionRef": {
          "module": "miroir-core/1_core/EntityPrimaryKey",
          "export": "parseCompositeKeyValue"
        },
        "arguments": [
          [
            "a",
            "b"
          ],
          "|x"
        ],
        "expectedValue": {
          "a": "",
          "b": "x"
        }
      },
