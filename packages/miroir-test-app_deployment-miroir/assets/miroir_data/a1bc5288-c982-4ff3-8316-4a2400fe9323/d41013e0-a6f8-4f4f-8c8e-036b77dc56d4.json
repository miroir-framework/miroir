              "table_name",
              "column_name"
            ]
          }
        ],
        "expectedValue": [
          "table_schema",
          "table_name",
          "column_name"
        ]
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "returns 'uuid' when idAttribute is not set",
        "functionRef": {
          "module": "miroir-core/1_core/EntityPrimaryKey",
          "export": "getEntityPrimaryKeyAttribute"
        },
        "arguments": [
