      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "resolves schemaReferences and flatten recursively",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/jzodObjectFlatten",
          "export": "jzodObjectFlatten"
        },
        "arguments": [
          {
            "type": "object",
            "extend": [
              {
                "type": "object",
                "definition": {
                  "a": {
                    "type": "string"
                  }
                }
              },
              {
                "type": "schemaReference",
                "definition": {
                  "relativePath": "SomeRef"
                }
              }
            ],
            "definition": {
              "b": {
                "type": "string"
              }
            }
          },
          {
            "SomeRef": {
              "type": "object",
              "definition": {
                "a": {
                  "type": "number"
                }
              }
            }
          }
        ],
        "environmentRef": "defaultMiroirModelEnvironment",
        "environmentArgumentIndex": 1,
        "expectedValue": {
          "type": "object",
          "definition": {
            "a": {
              "type": "number"
            },
            "b": {
              "type": "string"
            }
          }
        }
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "copies optional, nullable, and tag properties",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/jzodObjectFlatten",
          "export": "jzodObjectFlatten"
        },
        "arguments": [
          {
            "type": "object",
            "extend": {
              "type": "object",
              "definition": {
                "a": {
                  "type": "string"
                }
              }
            },
            "definition": {
              "b": {
                "type": "number"
              }
            },
            "optional": true,
            "nullable": true,
            "tag": {}
          }
        ],
        "environmentRef": "defaultMiroirModelEnvironment",
        "environmentArgumentIndex": 1,
        "expectedValue": {
          "type": "object",
          "definition": {
            "a": {
              "type": "string"
            },
            "b": {
              "type": "number"
            }
          },
          "optional": true,
          "nullable": true,
          "tag": {}
        }
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "resolves reference chains (reference -> reference -> object)",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/jzodObjectFlatten",
          "export": "jzodObjectFlatten"
        },
        "arguments": [
          {
            "type": "object",
            "extend": {
              "type": "schemaReference",
              "definition": {
                "relativePath": "IntermediateRef"
              }
            },
            "definition": {
              "myProp": {
                "type": "number"
              }
            }
          },
          {
            "FinalObject": {
              "type": "object",
              "definition": {
                "finalProp": {
                  "type": "string"
                }
              }
            },
            "IntermediateRef": {
              "type": "schemaReference",
              "definition": {
                "relativePath": "FinalObject"
              }
            }
          }
        ],
        "environmentRef": "defaultMiroirModelEnvironment",
        "environmentArgumentIndex": 1,
        "expectedValue": {
          "type": "object",
          "definition": {
            "finalProp": {
              "type": "string"
            },
            "myProp": {
              "type": "number"
            }
          }
        }
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "detects circular references and throws an error",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/jzodObjectFlatten",
          "export": "jzodObjectFlatten"
        },
        "arguments": [
          {
            "type": "object",
            "extend": {
              "type": "schemaReference",
              "definition": {
                "relativePath": "Ref2"
              }
            },
            "definition": {
              "myProp": {
                "type": "string"
              }
            }
          },
          {
            "Ref1": {
              "type": "schemaReference",
              "definition": {
                "relativePath": "Ref2"
              }
            },
            "Ref2": {
              "type": "schemaReference",
              "definition": {
                "relativePath": "Ref1"
              }
            }
          }
        ],
        "environmentRef": "defaultMiroirModelEnvironment",
        "environmentArgumentIndex": 1,
        "expectedError": "Circular reference detected"
      }
    ]
