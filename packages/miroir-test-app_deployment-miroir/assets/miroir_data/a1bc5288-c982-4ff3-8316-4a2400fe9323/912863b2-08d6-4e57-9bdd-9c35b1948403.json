    "unitTests": [
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "returns the same object if there is no extend",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/jzodObjectFlatten",
          "export": "jzodObjectFlatten"
        },
        "arguments": [
          {
            "type": "object",
            "definition": {
              "foo": {
                "type": "string"
              }
            }
          }
        ],
        "environmentRef": "defaultMiroirModelEnvironment",
        "environmentArgumentIndex": 1,
        "expectedValue": {
          "type": "object",
          "definition": {
            "foo": {
              "type": "string"
            }
          }
        }
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "flattens a single-level extend",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/jzodObjectFlatten",
          "export": "jzodObjectFlatten"
        },
        "arguments": [
          {
            "type": "object",
            "extend": {
              "type": "object",
              "definition": {
                "a": {
                  "type": "string"
                },
                "b": {
                  "type": "number"
                }
              }
            },
            "definition": {
              "b": {
                "type": "boolean"
              },
              "c": {
                "type": "bigint"
              }
            }
          }
        ],
        "environmentRef": "defaultMiroirModelEnvironment",
        "environmentArgumentIndex": 1,
        "expectedValue": {
          "type": "object",
          "definition": {
            "a": {
              "type": "string"
            },
            "b": {
              "type": "boolean"
            },
            "c": {
              "type": "bigint"
            }
          }
        }
      },
