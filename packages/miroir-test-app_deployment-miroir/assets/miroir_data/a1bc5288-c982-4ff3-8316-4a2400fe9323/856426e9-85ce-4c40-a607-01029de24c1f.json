        "expectedValue": {
          "type": "number"
        }
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "converts boolean type",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/JzodToJsonSchema",
          "export": "jzodToJsonSchema"
        },
        "arguments": [
          {
            "type": "boolean"
          }
        ],
        "expectedValue": {
          "type": "boolean"
        }
      },
      {
        "unitTestType": "functionCallTest",
