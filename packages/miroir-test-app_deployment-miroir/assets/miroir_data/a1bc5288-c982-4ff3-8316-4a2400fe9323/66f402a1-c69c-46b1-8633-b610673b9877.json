  "name": "getAttributeTypesFromJzodSchema",
  "description": "Phase 5c — getAttributeTypesFromJzodSchema (miroir-store-postgres)",
  "definition": {
    "unitTestType": "unitTestSuite",
    "unitTestLabel": "getAttributeTypesFromJzodSchema",
    "unitTests": [
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "should throw an error when jzodElement has no type",
        "functionRef": {
          "module": "miroir-store-postgres/1_core/mlSchema",
          "export": "getAttributeTypesFromJzodSchema"
        },
        "arguments": [
          {
            "definition": {}
          }
        ],
        "expectedError": "MlSchema has no type"
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "should throw an error when jzodElement type is not object",
        "functionRef": {
          "module": "miroir-store-postgres/1_core/mlSchema",
          "export": "getAttributeTypesFromJzodSchema"
        },
        "arguments": [
          {
            "type": "string",
            "definition": {}
          }
        ],
        "expectedError": "MlSchema type is not object"
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "should throw an error for unsupported attribute type",
        "functionRef": {
          "module": "miroir-store-postgres/1_core/mlSchema",
          "export": "getAttributeTypesFromJzodSchema"
        },
        "arguments": [
          {
            "type": "object",
            "definition": {
              "field": {
                "type": "unsupported"
              }
            }
          }
        ],
        "expectedError": "Jzod type unsupported not supported"
      },
      {
        "unitTestType": "functionCallTest",
        "unitTestLabel": "should return attribute types for valid jzodElement",
        "functionRef": {
          "module": "miroir-store-postgres/1_core/mlSchema",
          "export": "getAttributeTypesFromJzodSchema"
        },
        "arguments": [
          {
            "type": "object",
            "definition": {
              "age": {
                "type": "number"
              },
              "name": {
                "type": "string"
              },
              "isActive": {
                "type": "boolean"
              }
            }
          }
        ],
        "expectedValue": {
          "age": "double precision",
          "name": "text",
          "isActive": "boolean"
        }
      }
    ]
  }
}