  "uuid": "bdf83d4d-f4dd-42c9-b2d6-41311d979083",
  "parentName": "MiroirTest",
  "parentUuid": "a311f363-e238-4203-bdfc-29e8c160c26b",
  "name": "mustache",
  "selfApplication": "360fcf1f-f0d4-4f8a-9262-07886e70fa15",
  "branch": "ad1ddc4e-556e-4598-9cff-706a2bde0be7",
  "description": "Phase 3b pilot — extractDoubleBracePatterns functionCallTest suite",
  "definition": {
    "miroirTestType": "miroirTestSuite",
    "miroirTestLabel": "mustache.extractDoubleBracePatterns",
    "miroirTests": [
      {
        "miroirTestType": "functionCallTest",
        "miroirTestLabel": "should extract patterns with double braces",
        "functionRef": {
          "module": "miroir-core/1_core/mustache",
          "export": "extractDoubleBracePatterns"
        },
        "arguments": [
          "Hello {{ name }}!"
        ],
        "expectedValue": [
          {
            "content": "name",
            "start": 6,
            "end": 15
          }
        ]
      },
      {
        "miroirTestType": "functionCallTest",
        "miroirTestLabel": "should extract patterns with name sequences",
        "functionRef": {
          "module": "miroir-core/1_core/mustache",
          "export": "extractDoubleBracePatterns"
        },
        "arguments": [
          "Hello {{ user.name }}!"
        ],
        "expectedValue": [
          {
            "content": "user.name",
            "start": 6,
            "end": 20
          }
        ]
      },
      {
        "miroirTestType": "functionCallTest",
        "miroirTestLabel": "should handle multiple patterns",
        "functionRef": {
          "module": "miroir-core/1_core/mustache",
          "export": "extractDoubleBracePatterns"
        },
        "arguments": [
          "Hello {{ name }}! Your age is {{ age }}."
        ],
        "expectedValue": [
          {
            "content": "name",
            "start": 6,
            "end": 15
          },
          {
            "content": "age",
            "start": 30,
            "end": 38
          }
        ]
      },
      {
        "miroirTestType": "functionCallTest",
        "miroirTestLabel": "should handle patterns with extra spaces",
        "functionRef": {
          "module": "miroir-core/1_core/mustache",
          "export": "extractDoubleBracePatterns"
        },
        "arguments": [
          "Hello {{  name  }}!"
        ],
        "expectedValue": [
          {
            "content": "name",
            "start": 6,
            "end": 17
          }
        ]
      },
      {
        "miroirTestType": "functionCallTest",
        "miroirTestLabel": "should return an empty array if no patterns are found",
        "functionRef": {
          "module": "miroir-core/1_core/mustache",
          "export": "extractDoubleBracePatterns"
        },
        "arguments": [
          "Hello world!"
        ],
        "expectedValue": []
      },
      {
        "miroirTestType": "functionCallTest",
        "miroirTestLabel": "should throw an error for empty patterns",
        "functionRef": {
          "module": "miroir-core/1_core/mustache",
          "export": "extractDoubleBracePatterns"
        },
        "arguments": [
          "Hello {{  }}!"
        ],
        "expectedError": "Empty pattern found"
      }
    ]
  }
}
