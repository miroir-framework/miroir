      {
        "miroirTestType": "functionCallTest",
        "miroirTestLabel": "flat object: sets rawSchema to ANY_SCHEMA, resolvedSchema to inferred object schema, valuePath/typePath, and embeds scalar children",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/jzodTypeCheck",
          "export": "buildAnyObjectEntry"
        },
        "arguments": [
          {
            "a": "hello",
            "b": 42
          },
          [
            "outer"
          ],
          [
            "outer"
          ]
        ],
        "assertions": [
          {
            "label": "rawSchema",
            "resultAccessPath": [
              "rawSchema"
            ],
            "expectedValue": {
              "type": "any"
            }
          },
          {
            "label": "resolvedSchema",
            "resultAccessPath": [
              "resolvedSchema"
            ],
            "expectedValue": {
              "type": "object",
              "definition": {
                "a": {
                  "type": "string"
                },
                "b": {
                  "type": "number"
                }
              }
            }
          },
          {
            "label": "valuePath",
            "resultAccessPath": [
              "valuePath"
            ],
            "expectedValue": [
              "outer"
            ]
          },
          {
            "label": "typePath",
            "resultAccessPath": [
              "typePath"
            ],
            "expectedValue": [
              "outer"
            ]
          },
          {
            "label": "a.rawSchema",
            "resultAccessPath": [
              "a",
              "rawSchema"
            ],
            "expectedValue": {
              "type": "any"
            }
          },
          {
            "label": "a.resolvedSchema",
            "resultAccessPath": [
              "a",
              "resolvedSchema"
            ],
            "expectedValue": {
              "type": "string"
            }
          },
          {
            "label": "a.valuePath",
            "resultAccessPath": [
              "a",
              "valuePath"
            ],
            "expectedValue": [
              "outer",
              "a"
            ]
          },
          {
            "label": "a.typePath",
            "resultAccessPath": [
              "a",
              "typePath"
            ],
            "expectedValue": [
              "outer",
              "a"
            ]
          },
          {
            "label": "b.rawSchema",
            "resultAccessPath": [
              "b",
              "rawSchema"
