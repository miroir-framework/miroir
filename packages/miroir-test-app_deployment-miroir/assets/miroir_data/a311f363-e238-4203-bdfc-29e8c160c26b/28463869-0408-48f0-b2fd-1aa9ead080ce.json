  "description": "Migrated from UnitTest 912863b2-08d6-4e57-9bdd-9c35b1948403 (Feature #196 Phase 5)",
  "definition": {
    "miroirTestType": "miroirTestSuite",
    "miroirTestLabel": "jzod.jzodObjectFlatten",
    "miroirTests": [
      {
        "miroirTestType": "functionCallTest",
        "miroirTestLabel": "returns the same object if there is no extend",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/jzodObjectFlatten",
          "export": "jzodObjectFlatten"
        },
        "arguments": [
          {
            "type": "object",
            "definition": {
              "foo": {
                "type": "string"
              }
            }
          }
        ],
        "environmentRef": "defaultMiroirModelEnvironment",
        "environmentArgumentIndex": 1,
        "expectedValue": {
          "type": "object",
          "definition": {
            "foo": {
              "type": "string"
            }
          }
        }
      },
      {
        "miroirTestType": "functionCallTest",
        "miroirTestLabel": "flattens a single-level extend",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/jzodObjectFlatten",
          "export": "jzodObjectFlatten"
        },
        "arguments": [
          {
            "type": "object",
            "extend": {
              "type": "object",
              "definition": {
                "a": {
                  "type": "string"
                },
                "b": {
                  "type": "number"
                }
              }
            },
            "definition": {
              "b": {
                "type": "boolean"
              },
              "c": {
                "type": "bigint"
              }
            }
          }
        ],
        "environmentRef": "defaultMiroirModelEnvironment",
        "environmentArgumentIndex": 1,
        "expectedValue": {
          "type": "object",
          "definition": {
            "a": {
              "type": "string"
            },
            "b": {
              "type": "boolean"
            },
            "c": {
              "type": "bigint"
            }
          }
        }
      },
      {
        "miroirTestType": "functionCallTest",
        "miroirTestLabel": "flattens multi-level extends",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/jzodObjectFlatten",
          "export": "jzodObjectFlatten"
        },
        "arguments": [
          {
            "type": "object",
            "extend": {
              "type": "object",
              "extend": {
                "type": "object",
                "definition": {
                  "a": {
                    "type": "string"
                  }
                }
              },
              "definition": {
                "b": {
                  "type": "number"
                }
              }
            },
            "definition": {
              "c": {
                "type": "boolean"
              }
            }
          }
        ],
        "environmentRef": "defaultMiroirModelEnvironment",
        "environmentArgumentIndex": 1,
        "expectedValue": {
          "type": "object",
          "definition": {
            "a": {
              "type": "string"
            },
            "b": {
              "type": "number"
            },
            "c": {
              "type": "boolean"
            }
          }
        }
      },
      {
        "miroirTestType": "functionCallTest",
        "miroirTestLabel": "flattens with array of extends",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/jzodObjectFlatten",
          "export": "jzodObjectFlatten"
        },
        "arguments": [
          {
            "type": "object",
            "extend": [
              {
                "type": "object",
                "definition": {
                  "a": {
                    "type": "string"
                  }
                }
              },
              {
                "type": "object",
                "definition": {
                  "b": {
                    "type": "number"
                  }
                }
              }
            ],
            "definition": {
              "c": {
                "type": "boolean"
              }
            }
          }
        ],
        "environmentRef": "defaultMiroirModelEnvironment",
        "environmentArgumentIndex": 1,
        "expectedValue": {
          "type": "object",
          "definition": {
            "a": {
              "type": "string"
            },
            "b": {
              "type": "number"
            },
            "c": {
              "type": "boolean"
            }
          }
        }
      },
      {
        "miroirTestType": "functionCallTest",
        "miroirTestLabel": "resolves schemaReferences and flatten recursively",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/jzodObjectFlatten",
          "export": "jzodObjectFlatten"
        },
        "arguments": [
          {
            "type": "object",
            "extend": [
              {
                "type": "object",
                "definition": {
                  "a": {
                    "type": "string"
                  }
                }
              },
              {
                "type": "schemaReference",
                "definition": {
                  "relativePath": "SomeRef"
                }
              }
            ],
            "definition": {
              "b": {
                "type": "string"
              }
            }
          },
          {
            "SomeRef": {
              "type": "object",
              "definition": {
                "a": {
                  "type": "number"
                }
              }
            }
          }
        ],
        "environmentRef": "defaultMiroirModelEnvironment",
        "environmentArgumentIndex": 1,
        "expectedValue": {
          "type": "object",
          "definition": {
            "a": {
              "type": "number"
            },
            "b": {
              "type": "string"
            }
          }
        }
      },
      {
        "miroirTestType": "functionCallTest",
        "miroirTestLabel": "copies optional, nullable, and tag properties",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/jzodObjectFlatten",
          "export": "jzodObjectFlatten"
        },
        "arguments": [
          {
            "type": "object",
            "extend": {
              "type": "object",
              "definition": {
                "a": {
                  "type": "string"
                }
              }
            },
            "definition": {
              "b": {
                "type": "number"
              }
            },
            "optional": true,
            "nullable": true,
            "tag": {}
          }
        ],
        "environmentRef": "defaultMiroirModelEnvironment",
        "environmentArgumentIndex": 1,
        "expectedValue": {
          "type": "object",
          "definition": {
            "a": {
              "type": "string"
            },
            "b": {
              "type": "number"
            }
          },
          "optional": true,
          "nullable": true,
          "tag": {}
        }
      },
      {
        "miroirTestType": "functionCallTest",
        "miroirTestLabel": "resolves reference chains (reference -> reference -> object)",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/jzodObjectFlatten",
          "export": "jzodObjectFlatten"
        },
        "arguments": [
          {
            "type": "object",
            "extend": {
              "type": "schemaReference",
              "definition": {
                "relativePath": "IntermediateRef"
              }
            },
            "definition": {
              "myProp": {
                "type": "number"
              }
            }
          },
          {
            "FinalObject": {
              "type": "object",
              "definition": {
                "finalProp": {
                  "type": "string"
                }
              }
            },
            "IntermediateRef": {
              "type": "schemaReference",
              "definition": {
                "relativePath": "FinalObject"
              }
            }
          }
        ],
        "environmentRef": "defaultMiroirModelEnvironment",
        "environmentArgumentIndex": 1,
        "expectedValue": {
          "type": "object",
          "definition": {
            "finalProp": {
              "type": "string"
            },
            "myProp": {
              "type": "number"
            }
          }
        }
      },
      {
        "miroirTestType": "functionCallTest",
        "miroirTestLabel": "detects circular references and throws an error",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/jzodObjectFlatten",
          "export": "jzodObjectFlatten"
        },
        "arguments": [
          {
            "type": "object",
            "extend": {
              "type": "schemaReference",
              "definition": {
                "relativePath": "Ref2"
              }
            },
            "definition": {
              "myProp": {
                "type": "string"
              }
            }
          },
          {
            "Ref1": {
              "type": "schemaReference",
              "definition": {
                "relativePath": "Ref2"
              }
            },
            "Ref2": {
              "type": "schemaReference",
              "definition": {
                "relativePath": "Ref1"
              }
            }
          }
        ],
        "environmentRef": "defaultMiroirModelEnvironment",
        "environmentArgumentIndex": 1,
        "expectedError": "Circular reference detected"
      }
    ]
  }
