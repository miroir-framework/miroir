        "functionRef": {
          "module": "miroir-core/1_core/jzod/JzodSchemaReferences",
          "export": "jzodTransitiveDependencySet"
        },
        "arguments": [
          {
            "type": "schemaReference",
            "definition": {
              "relativePath": "root"
            },
            "context": {
              "root": {
                "type": "object",
                "definition": {
                  "a": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "root"
