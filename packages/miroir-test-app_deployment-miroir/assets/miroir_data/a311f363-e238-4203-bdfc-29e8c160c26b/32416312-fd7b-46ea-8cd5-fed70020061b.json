                    "type": "schemaReference",
                    "definition": {
                      "relativePath": "B"
                    }
                  }
                }
              },
              "B": {
                "type": "string"
              }
            }
          },
          "A"
        ],
        "expectedValue": [
          "A",
          "B"
        ]
      },
      {
