  "description": "Migrated from UnitTest e2f3a4b5-c6d7-4e8f-9a01-b2c3d4e5f6a7 (Feature #196 Phase 5)",
  "definition": {
    "miroirTestType": "miroirTestSuite",
    "miroirTestLabel": "jzod.JzodSchemaReferencesSet",
    "miroirTests": [
      {
        "miroirTestType": "functionCallTest",
        "miroirTestLabel": "returns empty array for a literal element",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/JzodSchemaReferences",
          "export": "JzodSchemaReferencesSet"
        },
        "arguments": [
          {
            "type": "literal",
            "definition": "testLiteral"
          }
        ],
        "expectedValue": []
      },
      {
        "miroirTestType": "functionCallTest",
        "miroirTestLabel": "detects a direct schemaReference element",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/JzodSchemaReferences",
          "export": "JzodSchemaReferencesSet"
        },
        "arguments": [
          {
            "type": "schemaReference",
            "definition": {
              "relativePath": "a"
            }
          }
        ],
        "expectedValue": [
          {
            "type": "schemaReference",
            "definition": {
              "relativePath": "a"
            }
          }
        ]
      },
      {
        "miroirTestType": "functionCallTest",
        "miroirTestLabel": "detects schemaReference in an object extend (single value)",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/JzodSchemaReferences",
          "export": "JzodSchemaReferencesSet"
        },
        "arguments": [
          {
            "type": "object",
            "extend": {
              "type": "schemaReference",
              "definition": {
                "relativePath": "extended"
              }
            },
            "definition": {
              "a": {
                "type": "string"
              }
            }
          }
        ],
        "expectedValue": [
          {
            "type": "schemaReference",
            "definition": {
              "relativePath": "extended"
            }
          }
        ]
      },
      {
        "miroirTestType": "functionCallTest",
        "miroirTestLabel": "detects schemaReference in an object extend (array)",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/JzodSchemaReferences",
          "export": "JzodSchemaReferencesSet"
        },
        "arguments": [
          {
            "type": "object",
            "extend": [
              {
                "type": "schemaReference",
                "definition": {
                  "relativePath": "first"
                }
              },
              {
                "type": "schemaReference",
                "definition": {
                  "relativePath": "second"
                }
              }
            ],
            "definition": {
              "a": {
                "type": "literal",
                "definition": "no-ref"
              }
            }
          }
        ],
        "expectedValue": [
          {
            "type": "schemaReference",
            "definition": {
              "relativePath": "first"
            }
          },
          {
            "type": "schemaReference",
            "definition": {
              "relativePath": "second"
            }
          }
        ]
      },
      {
        "miroirTestType": "functionCallTest",
        "miroirTestLabel": "detects schemaReference in an object extend and definition",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/JzodSchemaReferences",
          "export": "JzodSchemaReferencesSet"
        },
        "arguments": [
          {
            "type": "object",
            "extend": {
              "type": "schemaReference",
              "definition": {
                "relativePath": "first"
              }
            },
            "definition": {
              "a": {
                "type": "schemaReference",
                "definition": {
                  "relativePath": "second"
                }
              }
            }
          }
        ],
        "expectedValue": [
          {
            "type": "schemaReference",
            "definition": {
              "relativePath": "first"
            }
          },
          {
            "type": "schemaReference",
            "definition": {
              "relativePath": "second"
            }
          }
        ]
      },
      {
        "miroirTestType": "functionCallTest",
        "miroirTestLabel": "detects schemaReference in an object definition without taking extend into account",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/JzodSchemaReferences",
          "export": "JzodSchemaReferencesSet"
        },
        "arguments": [
          {
            "type": "object",
            "extend": {
              "type": "schemaReference",
              "definition": {
                "relativePath": "first"
              }
            },
            "definition": {
              "a": {
                "type": "schemaReference",
                "definition": {
                  "relativePath": "second"
                }
              }
            }
          },
          false
        ],
        "expectedValue": [
          {
            "type": "schemaReference",
            "definition": {
              "relativePath": "second"
            }
          }
        ]
      },
      {
        "miroirTestType": "functionCallTest",
        "miroirTestLabel": "recursively detects schemaReference in union definitions",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/JzodSchemaReferences",
          "export": "JzodSchemaReferencesSet"
