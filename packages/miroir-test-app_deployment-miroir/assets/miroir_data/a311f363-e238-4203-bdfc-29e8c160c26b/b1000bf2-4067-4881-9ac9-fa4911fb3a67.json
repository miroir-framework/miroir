            ]
          }
        ],
        "expectedValue": [
          {
            "type": "schemaReference",
            "definition": {
              "relativePath": "unionRef"
            }
          }
        ]
      },
      {
        "miroirTestType": "functionCallTest",
        "miroirTestLabel": "recursively detects schemaReference in intersection definitions",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/JzodSchemaReferences",
          "export": "JzodSchemaReferencesSet"
        },
        "arguments": [
          {
            "type": "intersection",
            "definition": {
              "left": {
                "type": "schemaReference",
                "definition": {
                  "relativePath": "left"
                }
              },
              "right": {
                "type": "schemaReference",
                "definition": {
                  "relativePath": "right"
                }
              }
            }
          }
        ],
        "expectedValue": [
          {
            "type": "schemaReference",
            "definition": {
              "relativePath": "left"
            }
          },
          {
            "type": "schemaReference",
            "definition": {
              "relativePath": "right"
            }
          }
        ]
      },
      {
        "miroirTestType": "functionCallTest",
        "miroirTestLabel": "recursively detects schemaReference in function arguments/returns",
        "functionRef": {
          "module": "miroir-core/1_core/jzod/JzodSchemaReferences",
          "export": "JzodSchemaReferencesSet"
        },
        "arguments": [
          {
            "type": "function",
            "definition": {
              "args": [
                {
                  "type": "schemaReference",
                  "definition": {
                    "relativePath": "argRef"
                  }
                },
                {
                  "type": "string"
                }
              ],
              "returns": {
                "type": "schemaReference",
                "definition": {
                  "relativePath": "returnRef"
                }
              }
            }
          }
        ],
        "expectedValue": [
          {
            "type": "schemaReference",
            "definition": {
              "relativePath": "argRef"
            }
          },
          {
            "type": "schemaReference",
            "definition": {
              "relativePath": "returnRef"
            }
          }
        ]
