{
  "name": "miroir-ai",
  "version": "1.0.0",
  "description": "LLM/AI assistant backend for Miroir Framework — CopilotKit Runtime endpoint exposing Miroir element generation tools",
  "main": "dist/index.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup --target=node20 --format esm src/index.ts --dts",
    "devBuild": "npm run build",
    "dev": "npm run build && node ./dist/index.js",
    "test": "cross-env NODE_ENV=test vitest run --poolOptions.threads.singleThread --bail=1",
    "testByFile": "cross-env NODE_ENV=test vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miroir-framework/miroir.git"
  },
  "author": "Miroir Framework <miroir-framework@protonmail.com>",
  "license": "MIT",
  "keywords": [
    "ai",
    "llm",
    "copilotkit",
    "miroir",
    "framework"
  ],
  "dependencies": {
    "@copilotkit/runtime": "^1.57.0",
    "openai": "^4.0.0",
    "@anthropic-ai/sdk": "^0.57.0",
    "@google/generative-ai": "^0.21.0",
    "miroir-core": "*",
    "express": "^4.18.2",
    "uuid": "^11.0.0",
    "loglevelnext": "^6.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.8.9",
    "cross-env": "^7.0.3",
    "tsup": "^8.0.0",
    "typescript": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
