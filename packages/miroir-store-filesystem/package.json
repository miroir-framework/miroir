{
  "name": "miroir-store-filesystem",
  "private": true,
  "version": "0.0.0",
  "description": "The Miroir implementation for accessing filesystem databases.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "type": "module",
  "author": "Miroir Framework <miroir-framework@protonmail.com>",
  "license": "MIT",
  "scripts": {
    "watch": "lerna watch --scope='miroir-store-filesystem' --include-dependencies -- lerna run build --scope='miroir-store-filesystem'",
    "build-tsup": "tsup",
    "build": "tsup",
    "devBuild": "npm run build",
    "copy-files": "copyfiles -u 1 src/**/*.json src/**/*.css dist/src",
    "test": "cross-env NODE_ENV=test vitest"
  },
  "dependencies": {
    "electron": "40.6.1",
    "miroir-core": "*",
    "pg": "^8.9.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.29.0",
    "vite": "7.3.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.3.1",
    "@types/jest": "^29.2.4",
    "copyfiles": "^2.4.1",
    "cross-env": "^7.0.3",
    "loglevelnext": "^6.0.0",
    "rimraf": "^4.1.1",
    "ts-jest": "^29.1.1",
    "tsconfig-paths": "^4.1.2",
    "typescript": "^6.0.0",
    "vite-plugin-node": "^7.0.0"
  }
}
