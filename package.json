{
  "name": "Miroir Framework",
  "version": "0.5.0-rc.1",
  "description": "Miroir Framework is a framework for building web applications.",
  "author": "Miroir Framework <miroir-framework@protonmail.com>",
  "homepage": "https://miroir-framework.github.io/miroir/",
  "bugs": "https://github.com/miroir-framework/miroir/issues",
  "license": "MIT",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "yaml": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "lerna": "^9.0.0",
    "typescript": "^6.0.2"
  },
  "scripts": {
    "nonreg": "python scripts/run-nonreg.py",
    "nonreg:unit": "python scripts/run-nonreg.py --tier unit --run-all",
    "nonreg:default": "python scripts/run-nonreg.py --tier default --run-all",
    "nonreg:fail-fast": "python scripts/run-nonreg.py --tier default --fail-fast"
  },
  "nx": {
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "npm run build",
          "cwd": "{projectRoot}"
        },
        "dependsOn": [
          "^build"
        ]
      },
      "devBuild": {
        "executor": "nx:run-commands",
        "options": {
          "command": "npm run devBuild",
          "cwd": "{projectRoot}"
        },
        "dependsOn": [
          "^devBuild"
        ]
      }
    }
  }
}
