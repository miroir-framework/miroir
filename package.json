{
  "name": "root",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "lerna": "^9.0.0",
    "typescript": "^6.0.2"
  },
  "nx": {
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "npm run build",
          "cwd": "{projectRoot}"
        },
        "dependsOn": ["^build"]
      },
      "devBuild": {
        "executor": "nx:run-commands",
        "options": {
          "command": "npm run devBuild",
          "cwd": "{projectRoot}"
        },
        "dependsOn": ["^devBuild"]
      }
    }
  }
}
